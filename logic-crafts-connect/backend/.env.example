# ============================================
# SERVER CONFIGURATION
# ============================================

PORT=3001
NODE_ENV=development

# ============================================
# MONGODB CONFIGURATION
# ============================================

MONGODB_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/logic_crafts_db?retryWrites=true&w=majority&appName=craft

# ============================================
# JWT CONFIGURATION
# ============================================

JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d

# ============================================
# FRONTEND CONFIGURATION
# ============================================

FRONTEND_URL=http://localhost:5173